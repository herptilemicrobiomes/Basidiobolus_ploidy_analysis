/*
 * conf/profile_nquire.config — resources for the nQuire ploidy pipeline.
 */

params {
    alndir        = "${launchDir}/aln"
    beddir        = "${launchDir}/bed"
    outdir        = "${launchDir}/results/nquire"
    min_cov_wg   = 5
    min_cov_sc   = 4
    min_cov_gene = 4
    min_mapq     = 20
}

workDir = "${launchDir}/work/nquire"

process {

    withLabel: 'quick' {
        cpus   = 2
        memory = '4 GB'
        time   = '30m'
        queue  = 'short'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load samtools
        """
    }

    withLabel: 'nquire' {
        cpus   = 8
        memory = '24 GB'
        time   = '4h'
        queue  = 'epyc'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load nQuire
            module load samtools
        """
    }
}

trace    { enabled = true; file = "${launchDir}/logs/nextflow/nquire_trace.txt";    overwrite = true; fields = 'task_id,name,status,exit,realtime,%cpu,rss,tag' }
report   { enabled = true; file = "${launchDir}/logs/nextflow/nquire_report.html";  overwrite = true }
timeline { enabled = true; file = "${launchDir}/logs/nextflow/nquire_timeline.html"; overwrite = true }
