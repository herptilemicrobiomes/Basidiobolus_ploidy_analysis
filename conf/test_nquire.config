/*
 * conf/test_nquire.config — stub/test profile for nQuire pipeline.
 *
 * Usage:
 *   nextflow run pipeline/ploidy/nquire.nf \
 *     -c nextflow.config -profile test -stub-run --n_test 2
 */

params {
    alndir  = "${launchDir}/aln"
    beddir  = "${launchDir}/bed"
    outdir  = "${launchDir}/tests/output/nquire"
    n_test  = 2
}

workDir = "${launchDir}/tests/work/nquire"

process {
    executor = 'local'

    withLabel: 'quick'  { cpus = 1; memory = '1 GB'; time = '10m'; beforeScript = ':' }
    withLabel: 'nquire' { cpus = 1; memory = '1 GB'; time = '10m'; beforeScript = ':' }
}
