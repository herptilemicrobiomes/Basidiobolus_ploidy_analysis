/*
 * nextflow.config — root config for Basidiobolus ploidy_analysis workflows.
 *
 * Activate a pipeline:   -profile <name>
 * Validate without jobs: -profile <name> -stub-run --n_test 2
 */

manifest {
    name            = 'Basidiobolus-ploidy'
    description     = 'nQuire ploidy estimation for Basidiobolus genomes'
    version         = '0.1'
    nextflowVersion = '>=23.10'
}

params {
    n_test = 0
}

executor {
    name            = 'slurm'
    queueSize       = 200
    submitRateLimit = '30/1min'
    pollInterval    = '1 min'
    exitReadTimeout = '30 min'
}

process {
    shell          = ['/bin/bash', '-l']
    errorStrategy  = { task.attempt < 3 ? 'retry' : 'finish' }
    maxRetries     = 2
    cache          = 'lenient'
    clusterOptions = '-N 1 -n 1'
    queue          = 'epyc'
}

singularity {
    enabled  = false
    cacheDir = '/bigdata/stajichlab/shared/lib/singularity_cache'
}

profiles {
    nquire { includeConfig 'conf/profile_nquire.config' }
    test   { includeConfig 'conf/test_nquire.config'    }
}
